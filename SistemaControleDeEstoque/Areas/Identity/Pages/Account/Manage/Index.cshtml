@page
@model SistemaControleDeEstoque.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-center pt-12">
    <div class="w-full max-w-sm">

        <!-- Cabeçalho -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Perfil</h1>
        </div>

        <!-- Status message -->
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            var isError = Model.StatusMessage.StartsWith("Erro");
            <div class="mb-4 flex items-start gap-3 border @(isError ? "border-red-300 dark:border-red-700" : "border-gray-200 dark:border-gray-800") rounded-lg p-4">
                <svg class="h-4 w-4 flex-shrink-0 mt-0.5 @(isError ? "text-red-500" : "text-gray-400 dark:text-gray-600")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    @if (isError)
                    {
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    }
                    else
                    {
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    }
                </svg>
                <p class="text-xs @(isError ? "text-red-600 dark:text-red-400" : "text-gray-500 dark:text-gray-400")">
                    @Model.StatusMessage
                </p>
            </div>
        }

        <!-- Formulário -->
        <form id="profile-form" method="post" class="space-y-4">

            <!-- Erros de validação -->
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-300 dark:border-red-700 rounded-md"
                 role="alert"></div>

            <!-- Grid de campos -->
            <div class="grid grid-cols-1 gap-4">

                <!-- Nome de usuário (somente leitura) -->
                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                        Nome de usuário
                    </label>
                    <input disabled value="@Model.Username"
                           class="w-full px-3 py-2 border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 text-gray-400 dark:text-gray-600 rounded-md text-sm cursor-not-allowed" />
                </div>

                <!-- Telefone -->
                <div>
                    <label asp-for="Input.NumTelefone"
                           class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1"></label>
                    <input asp-for="Input.NumTelefone"
                           id="input-telefone"
                           placeholder="(00) 00000-0000"
                           maxlength="15"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Input.NumTelefone" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

            </div>

            <!-- Botão -->
            <button type="submit"
                    class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Salvar
            </button>

        </form>

        <!-- Link Voltar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Voltar para o início
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // ── Máscara de telefone: (00) 00000-0000 ──────────────────────
        (function () {
            var input = document.getElementById('input-telefone');
            if (!input) return;

            // Formata o valor atual ao carregar (dígitos brutos vindos do banco)
            input.value = mascararTelefone(input.value);

            input.addEventListener('input', function (e) {
                var pos = e.target.selectionStart;
                e.target.value = mascararTelefone(e.target.value);
            });

            function mascararTelefone(v) {
                // Remove tudo que não é dígito e limita a 11 dígitos
                v = v.replace(/\D/g, '').substring(0, 11);
                if      (v.length > 7) v = '(' + v.substring(0, 2) + ') ' + v.substring(2, 7) + '-' + v.substring(7);
                else if (v.length > 2) v = '(' + v.substring(0, 2) + ') ' + v.substring(2);
                else if (v.length > 0) v = '(' + v;
                return v;
            }

            // Antes de submeter, limpa a máscara - envia só dígitos ao servidor
            document.getElementById('profile-form').addEventListener('submit', function () {
                input.value = input.value.replace(/\D/g, '');
            });
        })();
    </script>
}
