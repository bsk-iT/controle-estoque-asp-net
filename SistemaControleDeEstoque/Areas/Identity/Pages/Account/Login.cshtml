@page
@model LoginModel

@{
    ViewData["Title"] = "Entrar";
}

<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm">

        <!-- Logo -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Bem-vindo de volta</h1>
        </div>

        <form id="account" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-300 dark:border-red-700 rounded-md"
                 role="alert"></div>

            <!-- Email -->
            <div>
                <label asp-for="Input.Email"
                       class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Email</label>
                <input asp-for="Input.Email"
                       class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150"
                       autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
            </div>

            <!-- Senha -->
            <div>
                <label asp-for="Input.Password"
                       class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Senha</label>
                <div class="relative">
                    <input asp-for="Input.Password"
                           class="w-full px-3 py-2 pr-10 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150"
                           autocomplete="current-password" aria-required="true" placeholder="Sua senha"
                           minlength="8" maxlength="100" />
                    <button type="button"
                            class="toggle-password absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150"
                            onclick="togglePasswordVisibility(this.parentNode.querySelector('input'))">
                        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                            <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
            </div>

            <!-- Lembrar de mim -->
            <div class="flex items-center">
                <input asp-for="Input.RememberMe"
                       class="h-3.5 w-3.5 border border-gray-300 dark:border-gray-700 rounded bg-white dark:bg-gray-950 text-black dark:text-white focus:ring-0 focus:ring-offset-0" />
                <label asp-for="Input.RememberMe"
                       class="ml-2 text-sm text-gray-600 dark:text-gray-400">Lembrar de mim</label>
            </div>

            <!-- Botão Entrar -->
            <button id="login-submit" type="submit"
                    class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Entrar
            </button>

            <!-- Links -->
            <div class="pt-3 border-t border-gray-100 dark:border-gray-900 space-y-2 text-center">
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword"
                       class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                        Esqueceu sua senha?
                    </a>
                </p>
                <p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                       class="text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                        Criar nova conta
                    </a>
                </p>
            </div>
        </form>

        <!-- Bloco de dicas -->
        <div class="mt-8 border border-gray-200 dark:border-gray-800 rounded-lg p-4">
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Dicas de segurança</p>
            <ul class="space-y-1.5">
                <li class="flex items-start gap-2 text-xs text-gray-500 dark:text-gray-400">
                    <span class="mt-1.5 h-1 w-1 rounded-full bg-black dark:bg-white flex-shrink-0"></span>
                    Nunca compartilhe suas credenciais
                </li>
                <li class="flex items-start gap-2 text-xs text-gray-500 dark:text-gray-400">
                    <span class="mt-1.5 h-1 w-1 rounded-full bg-black dark:bg-white flex-shrink-0"></span>
                    Use conexões seguras (HTTPS)
                </li>
                <li class="flex items-start gap-2 text-xs text-gray-500 dark:text-gray-400">
                    <span class="mt-1.5 h-1 w-1 rounded-full bg-black dark:bg-white flex-shrink-0"></span>
                    Saia da conta em dispositivos compartilhados
                </li>
            </ul>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePasswordVisibility(passwordInput) {
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                passwordInput.parentNode.querySelector('.toggle-password svg').innerHTML = `
                    <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                    <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.065 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                `;
            } else {
                passwordInput.type = 'password';
                passwordInput.parentNode.querySelector('.toggle-password svg').innerHTML = `
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                `;
            }
        }
    </script>
}
