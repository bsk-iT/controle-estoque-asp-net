@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperação de Senha";
}

<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm">

        <!-- Cabeçalho -->
        <div class="mb-8">
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Recuperar senha</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Informe seu e-mail para receber o link de recuperação.</p>
        </div>

        <!-- Formulário -->
        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-200 dark:border-red-800 rounded-md"
                 role="alert"></div>

            <!-- Email -->
            <div>
                <label asp-for="Input.Email"
                       class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">
                    E-mail
                </label>
                <input asp-for="Input.Email"
                       class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
            </div>

            <!-- Botão -->
            <button type="submit"
                    class="w-full px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Enviar link de recuperação
            </button>
        </form>

        <!-- Links -->
        <div class="mt-6 flex justify-between text-sm">
            <a asp-page="./Login"
               class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                ← Voltar para login
            </a>
            <a asp-page="./Register"
               class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                Criar conta
            </a>
        </div>

        <!-- Dicas -->
        <div class="mt-8 border border-gray-200 dark:border-gray-800 rounded-lg p-4">
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Observações</p>
            <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-black dark:bg-white flex-shrink-0"></span>
                    Verifique a pasta de spam caso não receba o e-mail
                </li>
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-black dark:bg-white flex-shrink-0"></span>
                    O link de recuperação é válido por tempo limitado
                </li>
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-black dark:bg-white flex-shrink-0"></span>
                    Use uma senha forte ao redefinir
                </li>
            </ul>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
