@page
@model LogoutModel
@{
    ViewData["Title"] = "Sair";
}

<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm text-center">

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <!-- Ícone de saída -->
            <div class="mx-auto mb-6 h-16 w-16 rounded-full border border-gray-200 dark:border-gray-800 flex items-center justify-center">
                <svg class="h-8 w-8 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
            </div>

            <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight mb-3"
                style="font-family: 'Playfair Display', Georgia, serif;">Sair do sistema</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">
                Deseja realmente encerrar sua sessão?
            </p>

            <!-- Ações -->
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <form asp-area="Identity" asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Page("/", new { area = "" })"
                      method="post">
                    <button type="submit"
                            class="inline-flex items-center justify-center gap-2 px-6 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        Confirmar saída
                    </button>
                </form>
                <a href="/"
                   class="inline-flex items-center justify-center gap-2 px-6 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-600 dark:text-gray-400 bg-transparent hover:border-black dark:hover:border-white hover:text-black dark:hover:text-white rounded transition-colors duration-200">
                    Cancelar
                </a>
            </div>
        }
        else
        {
            <!-- Ícone de sucesso -->
            <div class="mx-auto mb-6 h-16 w-16 rounded-full border border-gray-200 dark:border-gray-800 flex items-center justify-center">
                <svg class="h-8 w-8 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
                </svg>
            </div>

            <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight mb-3"
                style="font-family: 'Playfair Display', Georgia, serif;">Até logo</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">
                Você saiu do sistema com segurança.
            </p>

            <a href="/"
               class="inline-flex items-center justify-center gap-2 px-6 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Voltar para a página inicial
            </a>
        }

        <!-- Dica de segurança -->
        <div class="mt-8 border border-gray-200 dark:border-gray-800 rounded-lg p-4 text-left">
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Dica de segurança</p>
            <p class="text-sm text-gray-600 dark:text-gray-400">
                Sempre saia do sistema ao usar um computador compartilhado ou público para proteger suas informações.
            </p>
        </div>

    </div>
</div>
