@model IdentityRole

<div class="flex justify-center pt-12">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Confirmar Exclusão</h1>
        </div>

        <!-- Alerta -->
        <div class="mb-6 flex items-start gap-3 border border-red-300 dark:border-red-700 rounded-lg p-4">
            <svg class="h-5 w-5 flex-shrink-0 mt-0.5 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-xs text-red-700 dark:text-red-300">
                Você está prestes a excluir este perfil. Esta ação não pode ser desfeita.
            </p>
        </div>

        <!-- Detalhes -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 mb-6">
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Perfil a excluir</p>
            <p class="text-black dark:text-white font-medium">@Model.Name</p>
        </div>

        <!-- Formulário -->
        <form id="delete-role-form" asp-action="Delete" method="post" class="space-y-4">
            <input type="hidden" asp-for="@Model.Id" />

            <!-- Botões -->
            <div class="flex gap-3">
                <a asp-action="Index"
                   class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-white bg-white dark:bg-gray-950 hover:bg-gray-50 dark:hover:bg-gray-900 rounded transition-colors duration-200 text-center">
                    Cancelar
                </a>
                <button type="button" id="open-modal-btn"
                        class="flex-1 px-4 py-2 border border-red-600 dark:border-red-500 text-sm font-medium text-red-600 dark:text-red-400 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 dark:hover:text-white rounded transition-colors duration-200">
                    Excluir
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal de confirmação final -->
<div id="deleteConfirmationModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50 dark:bg-black/70 backdrop-blur-sm"></div>
    
    <!-- Modal -->
    <div class="relative w-full max-w-sm mx-4 bg-white dark:bg-gray-950 rounded-lg shadow-lg border border-gray-200 dark:border-gray-800 p-6">
        <h3 class="text-lg font-medium text-black dark:text-white mb-3">Confirmar exclusão</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
            Tem certeza que deseja excluir o perfil <strong class="text-black dark:text-white">@Model.Name</strong>? Esta ação não pode ser desfeita.
        </p>
        
        <div class="flex gap-3">
            <button type="button" id="cancelDeleteBtn"
                    class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-white bg-white dark:bg-gray-950 hover:bg-gray-50 dark:hover:bg-gray-900 rounded transition-colors duration-200">
                Cancelar
            </button>
            <button type="button" id="confirmDeleteBtn"
                    class="flex-1 px-4 py-2 border border-red-600 dark:border-red-500 text-sm font-medium text-red-600 dark:text-red-400 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 dark:hover:text-white rounded transition-colors duration-200">
                Excluir
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal = document.getElementById('deleteConfirmationModal');
        const openModalBtn = document.getElementById('open-modal-btn');
        const confirmBtn = document.getElementById('confirmDeleteBtn');
        const cancelBtn = document.getElementById('cancelDeleteBtn');
        const deleteForm = document.getElementById('delete-role-form');

        // Abrir modal
        openModalBtn.addEventListener('click', function () {
            modal.classList.remove('hidden');
        });

        // Cancelar - fecha o modal
        cancelBtn.addEventListener('click', function () {
            modal.classList.add('hidden');
        });

        // Confirmar - submete o form
        confirmBtn.addEventListener('click', function () {
            deleteForm.submit();
        });
        
        // Fechar modal ao clicar no backdrop
        modal.addEventListener('click', function (e) {
            if (e.target === modal) {
                modal.classList.add('hidden');
            }
        });
    </script>
}
