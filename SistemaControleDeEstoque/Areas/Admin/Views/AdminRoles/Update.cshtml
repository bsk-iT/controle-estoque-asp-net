@model RoleEdit

<div class="flex flex-col gap-8">
    <!-- Cabeçalho -->
    <div class="text-center">
        <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
        <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
            style="font-family: 'Playfair Display', Georgia, serif;">@(Model.Role?.Name ?? "Perfil")</h1>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">Gerenciar membros do perfil</p>
    </div>

    <!-- Erros de validação -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="text-sm text-red-600 dark:text-red-400 p-4 border border-red-300 dark:border-red-700 rounded-md" role="alert">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form method="post" class="space-y-8">
        <input type="hidden" name="roleName" value="@(Model.Role?.Name ?? string.Empty)" />
        <input type="hidden" name="roleId" value="@(Model.Role?.Id ?? string.Empty)" />

        <!-- Adicionar Usuários -->
        <div class="space-y-4">
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Adicionar ao Perfil</h2>
            
            <div class="overflow-x-auto border border-gray-200 dark:border-gray-800 rounded">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-800">
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Usuário</th>
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Selecionar</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
                        @if (Model.NonMembers?.Count() == 0)
                        {
                            <tr>
                                <td colspan="2" class="px-6 py-4 text-center text-sm text-gray-600 dark:text-gray-400">
                                    Todos os usuários já pertencem a este perfil
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (IdentityUser user in Model.NonMembers!)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                                    <td class="px-6 py-4 text-gray-900 dark:text-gray-100">@user.UserName</td>
                                    <td class="px-6 py-4 text-center">
                                        <input type="checkbox" name="AddIds" value="@user.Id"
                                               class="h-4 w-4 border-gray-300 dark:border-gray-700 rounded" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Remover Usuários -->
        <div class="space-y-4">
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Remover do Perfil</h2>
            
            <div class="overflow-x-auto border border-gray-200 dark:border-gray-800 rounded">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-800">
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Usuário</th>
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Selecionar</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
                        @if (Model.Members?.Count() == 0)
                        {
                            <tr>
                                <td colspan="2" class="px-6 py-4 text-center text-sm text-gray-600 dark:text-gray-400">
                                    Não existem usuários neste perfil
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (IdentityUser user in Model.Members!)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                                    <td class="px-6 py-4 text-gray-900 dark:text-gray-100">@user.UserName</td>
                                    <td class="px-6 py-4 text-center">
                                        <input type="checkbox" name="DeleteIds" value="@user.Id"
                                               class="h-4 w-4 border-gray-300 dark:border-gray-700 rounded" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Botões -->
        <div class="border-t border-gray-100 dark:border-gray-900 pt-6 flex gap-3">
            <a asp-action="Index"
               class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-white bg-white dark:bg-gray-950 hover:bg-gray-50 dark:hover:bg-gray-900 rounded transition-colors duration-200 text-center">
                Voltar
            </a>
            <button type="submit"
                    class="flex-1 px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Salvar
            </button>
        </div>
    </form>
</div>
