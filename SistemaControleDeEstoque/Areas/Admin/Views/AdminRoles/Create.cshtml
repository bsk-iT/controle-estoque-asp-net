@model string

<div class="flex justify-center pt-12">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Criar Perfil</h1>
        </div>

        <!-- Formulário -->
        <form asp-action="Create" method="post" class="space-y-4">
            <!-- Erros de validação -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-300 dark:border-red-700 rounded-md" role="alert">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <!-- Nome do Perfil -->
            <div>
                <label for="name" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    Nome do Perfil
                </label>
                <input name="name"
                       id="name"
                       placeholder="Ex: Gerente, Operador"
                       class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
            </div>

            <!-- Botões -->
            <div class="flex gap-3 pt-6">
                <a asp-action="Index"
                   class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-white bg-white dark:bg-gray-950 hover:bg-gray-50 dark:hover:bg-gray-900 rounded transition-colors duration-200 text-center">
                    Voltar
                </a>
                <button type="submit"
                        class="flex-1 px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                    Criar
                </button>
            </div>
        </form>
    </div>
</div>
