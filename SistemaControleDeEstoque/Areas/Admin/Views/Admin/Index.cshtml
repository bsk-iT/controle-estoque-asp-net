@{
    ViewData["Title"] = "Administração";
}

<div class="flex flex-col gap-12">
    <!-- Cabeçalho -->
    <div class="text-center">
        <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-2">inventarii</p>
        <h1 class="text-3xl font-light text-black dark:text-white tracking-tight"
            style="font-family: 'Playfair Display', Georgia, serif;">Administração</h1>
    </div>

    <!-- Cards de Ações Principais -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Card Usuários -->
        <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Index"
           class="p-6 border border-black dark:border-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black rounded transition-colors duration-200 group">
            <div class="flex items-start gap-4">
                <svg class="h-6 w-6 text-black dark:text-white group-hover:text-white dark:group-hover:text-black mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <div class="flex-1">
                    <h3 class="text-lg font-medium text-black dark:text-white group-hover:text-white dark:group-hover:text-black">Gerenciar Usuários</h3>
                    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 group-hover:text-white dark:group-hover:text-black">
                        Adicione, edite ou remova usuários do sistema.
                    </p>
                </div>
            </div>
        </a>

        <!-- Card Perfis -->
        <a asp-area="Admin" asp-controller="AdminRoles" asp-action="Index"
           class="p-6 border border-black dark:border-white bg-transparent hover:bg-black dark:hover:bg-white hover:text-white dark:hover:text-black rounded transition-colors duration-200 group">
            <div class="flex items-start gap-4">
                <svg class="h-6 w-6 text-black dark:text-white group-hover:text-white dark:group-hover:text-black mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div class="flex-1">
                    <h3 class="text-lg font-medium text-black dark:text-white group-hover:text-white dark:group-hover:text-black">Gerenciar Perfis</h3>
                    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 group-hover:text-white dark:group-hover:text-black">
                        Configure permissões e grupos de acesso.
                    </p>
                </div>
            </div>
        </a>
    </div>

    <!-- Estatísticas do Sistema -->
    <div class="space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Visão Geral</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="border border-gray-200 dark:border-gray-800 rounded p-6">
                <div class="flex items-center gap-4">
                    <svg class="h-5 w-5 text-gray-400 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <div>
                        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total de Usuários</p>
                        <p class="text-2xl font-semibold text-black dark:text-white">@ViewBag.TotalUsuarios</p>
                    </div>
                </div>
            </div>

            <div class="border border-gray-200 dark:border-gray-800 rounded p-6">
                <div class="flex items-center gap-4">
                    <svg class="h-5 w-5 text-gray-400 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <div>
                        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Produtos Cadastrados</p>
                        <p class="text-2xl font-semibold text-black dark:text-white">@ViewBag.TotalProdutos</p>
                    </div>
                </div>
            </div>

            <div class="border border-gray-200 dark:border-gray-800 rounded p-6">
                <div class="flex items-center gap-4">
                    <svg class="h-5 w-5 text-gray-400 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Operações Hoje</p>
                        <p class="text-2xl font-semibold text-black dark:text-white">@ViewBag.OperacoesHoje</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Link Voltar -->
    <div class="border-t border-gray-100 dark:border-gray-900 pt-6 text-center">
        <a asp-area="" asp-controller="Home" asp-action="Index"
           class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Voltar para o início
        </a>
    </div>
</div>
