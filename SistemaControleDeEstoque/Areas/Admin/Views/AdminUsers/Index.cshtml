@model IEnumerable<IdentityUser>

<div class="flex flex-col gap-8">
    <!-- Cabeçalho -->
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="text-center sm:text-left">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-3xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Gerenciar Usuários</h1>
        </div>
        @if (Model.Any())
        {
            <a asp-area="Identity" asp-page="/Account/Register"
               class="w-full sm:w-auto px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200 text-center">
                Novo Usuário
            </a>
        }
    </div>

    <!-- Tabela de Usuários -->
    @if (Model.Any())
    {
        <div class="overflow-x-auto border border-gray-200 dark:border-gray-800 rounded">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-800">
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Usuário</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider">Ação</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                            <td class="px-6 py-4 text-gray-900 dark:text-gray-100">@user.UserName</td>
                            <td class="px-6 py-4 text-gray-600 dark:text-gray-400">@user.Email</td>
                            <td class="px-6 py-4 text-right">
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="inline delete-user-form">
                                    <button type="submit"
                                            class="px-3 py-1.5 border border-red-600 dark:border-red-500 text-xs font-medium text-red-600 dark:text-red-400 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 dark:hover:text-white rounded transition-colors duration-200">
                                        Excluir
                                    </button>
                                    <input type="hidden" name="userName" value="@user.UserName" />
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-12">
            <svg class="mx-auto h-10 w-10 text-gray-400 dark:text-gray-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">Nenhum usuário cadastrado</p>
            <a asp-area="Identity" asp-page="/Account/Register"
               class="inline-block px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Novo Usuário
            </a>
        </div>
    }

    <!-- Link Voltar -->
    <div class="border-t border-gray-100 dark:border-gray-900 pt-6 text-center">
        <a asp-area="Admin" asp-controller="Admin" asp-action="Index"
           class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Voltar para o painel
        </a>
    </div>
</div>

<!-- Modal de confirmação para exclusão -->
<div id="deleteConfirmationModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50 dark:bg-black/70 backdrop-blur-sm"></div>
    
    <!-- Modal -->
    <div class="relative w-full max-w-sm mx-4 bg-white dark:bg-gray-950 rounded-lg shadow-lg border border-gray-200 dark:border-gray-800 p-6">
        <h3 class="text-lg font-medium text-black dark:text-white mb-3">Confirmar exclusão</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
            Tem certeza que deseja excluir o usuário <strong id="userNameToDelete"></strong>? Esta ação não pode ser desfeita.
        </p>
        
        <div class="flex gap-3">
            <button type="button" id="cancelDeleteBtn"
                    class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-white bg-white dark:bg-gray-950 hover:bg-gray-50 dark:hover:bg-gray-900 rounded transition-colors duration-200">
                Cancelar
            </button>
            <button type="button" id="confirmDeleteBtn"
                    class="flex-1 px-4 py-2 border border-red-600 dark:border-red-500 text-sm font-medium text-red-600 dark:text-red-400 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 dark:hover:text-white rounded transition-colors duration-200">
                Excluir
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Elementos do modal
        const modal = document.getElementById('deleteConfirmationModal');
        const userNameElement = document.getElementById('userNameToDelete');
        const confirmBtn = document.getElementById('confirmDeleteBtn');
        const cancelBtn = document.getElementById('cancelDeleteBtn');
        
        // Formulário atual a ser enviado
        let currentForm = null;

        // Adicionar evento em todos os formulários de exclusão
        document.querySelectorAll('.delete-user-form').forEach(form => {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                
                // Guardar referência ao formulário atual
                currentForm = this;
                
                // Obter o nome do usuário do campo oculto
                const userName = this.querySelector('input[name="userName"]').value;
                
                // Atualizar o texto do modal com o nome do usuário
                userNameElement.textContent = userName;
                
                // Mostrar o modal
                modal.classList.remove('hidden');
            });
        });

        // Botão de cancelar - fecha o modal
        cancelBtn.addEventListener('click', function () {
            modal.classList.add('hidden');
            currentForm = null;
        });

        // Botão de confirmar - envia o formulário
        confirmBtn.addEventListener('click', function () {
            if (currentForm) {
                currentForm.submit();
            }
            modal.classList.add('hidden');
        });
        
        // Fechar modal ao clicar no backdrop
        modal.addEventListener('click', function (e) {
            if (e.target === modal) {
                modal.classList.add('hidden');
                currentForm = null;
            }
        });
    </script>
}
