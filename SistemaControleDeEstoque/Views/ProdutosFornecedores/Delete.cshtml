@model SistemaControleDeEstoque.Models.ProdutoFornecedor

@{
    ViewData["Title"] = "Excluir Associação";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-red-600 dark:text-red-500 tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Excluir Associação</h1>
        </div>

        <!-- Alerta -->
        <div class="mb-6 border border-red-200 dark:border-red-900 rounded-lg p-4">
            <p class="text-sm font-medium text-red-700 dark:text-red-400">Tem certeza que deseja excluir esta associação?</p>
            <p class="text-sm text-red-600 dark:text-red-500 mt-1">Esta ação não pode ser desfeita.</p>
        </div>

        <!-- Campos em lista vertical -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg divide-y divide-gray-100 dark:divide-gray-800 mb-6">
            <!-- Produto -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Produto)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @Html.DisplayFor(model => model.Produto.Nome)
                </p>
            </div>
            <!-- Fornecedor -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Fornecedor)
                </p>
                <div class="space-y-1">
                    <p class="text-sm font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(model => model.Fornecedor.Nome)
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">
                        CNPJ: @Html.DisplayFor(model => model.Fornecedor.CNPJ)
                    </p>
                </div>
            </div>
        </div>

        <!-- Formulário de exclusão -->
        <form asp-action="Delete" onsubmit="return confirmarExclusao(event)">
            <input type="hidden" asp-for="Id" />
            <button type="submit"
                    class="w-full py-2 px-4 border border-red-600 dark:border-red-500 text-sm font-medium text-red-600 dark:text-red-500 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 rounded transition-colors duration-200">
                Confirmar Exclusão
            </button>
        </form>

        <!-- Rodapé: link de navegação -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index" class="text-xs text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                Cancelar
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarExclusao(event) {
            if (!window.confirm('Tem certeza que deseja excluir esta associação? Esta ação não pode ser desfeita.')) {
                event.preventDefault();
                return false;
            }
            return true;
        }
    </script>
}
