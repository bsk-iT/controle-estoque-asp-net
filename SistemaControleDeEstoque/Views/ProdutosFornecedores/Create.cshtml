@model SistemaControleDeEstoque.Models.ProdutoFornecedor

@{
    ViewData["Title"] = "Nova Associação";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Nova Associação</h1>
        </div>

        <form asp-action="Create" method="post" class="space-y-6">

            <!-- Validação -->
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-200 dark:border-red-800 rounded-md" role="alert"></div>

            <!-- Produto -->
            <div>
                <label asp-for="ProdutoId" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Produto</label>
                <select asp-for="ProdutoId" asp-items="ViewBag.ProdutoId"
                        class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                    <option value="">Selecione um produto...</option>
                </select>
                <span asp-validation-for="ProdutoId" class="text-xs text-red-600 dark:text-red-400"></span>
            </div>

            <!-- Fornecedor -->
            <div>
                <label asp-for="FornecedorId" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Fornecedor</label>
                <select asp-for="FornecedorId" asp-items="ViewBag.FornecedorId"
                        class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                    <option value="">Selecione um fornecedor...</option>
                </select>
                <span asp-validation-for="FornecedorId" class="text-xs text-red-600 dark:text-red-400"></span>
            </div>

            <!-- Botão -->
            <button type="submit"
                    class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Criar Associação
            </button>
        </form>

        <!-- Link Voltar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index"
               class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Voltar
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
