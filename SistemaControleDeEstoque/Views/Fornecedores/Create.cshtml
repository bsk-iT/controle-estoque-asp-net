@model SistemaControleDeEstoque.Models.Fornecedor

@{
    ViewData["Title"] = "Novo Fornecedor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-center pt-12">
    <div class="w-full max-w-sm">

        <!-- Logo -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Novo Fornecedor</h1>
        </div>

        <!-- Formulário -->
        <form asp-action="Create" method="post" class="space-y-4">

            <!-- Erros de validação -->
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-300 dark:border-red-700 rounded-md"
                 role="alert"></div>

            <!-- Grid de campos -->
            <div class="grid grid-cols-1 gap-4">

                <!-- Nome -->
                <div>
                    <label asp-for="Nome" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1"></label>
                    <input asp-for="Nome"
                           placeholder="Nome do fornecedor"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Nome" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- CNPJ -->
                <div>
                    <label asp-for="CNPJ" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1"></label>
                    <input asp-for="CNPJ"
                           placeholder="00.000.000/0000-00"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="CNPJ" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1"></label>
                    <input asp-for="Email" type="email"
                           placeholder="fornecedor@empresa.com"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Email" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Telefone -->
                <div>
                    <label asp-for="Telefone" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1"></label>
                    <input asp-for="Telefone"
                           placeholder="(00) 00000-0000"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Telefone" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

            </div>

            <!-- Observação -->
            <div class="flex items-start gap-3 border border-gray-200 dark:border-gray-800 rounded-lg p-4">
                <svg class="h-4 w-4 text-gray-400 dark:text-gray-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                </svg>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                    Os fornecedores cadastrados poderão ser associados aos produtos do sistema.
                    Certifique-se de inserir dados válidos e completos.
                </p>
            </div>

            <!-- Botão -->
            <button type="submit"
                    class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Cadastrar
            </button>

        </form>

        <!-- Link Voltar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index"
               class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Voltar para Fornecedores
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
