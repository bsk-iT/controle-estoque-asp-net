@model SistemaControleDeEstoque.Models.Fornecedor

@{
    ViewData["Title"] = "Excluir Fornecedor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-center pt-3">
    <div class="w-full max-w-sm">

        <!-- Logo -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-red-600 dark:text-red-500 tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Excluir Fornecedor</h1>
        </div>

        <!-- Alerta de confirmação -->
        <div class="flex items-start gap-3 border border-red-200 dark:border-red-900 rounded-lg p-4 mb-6">
            <svg class="h-4 w-4 text-red-500 dark:text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
                <p class="text-sm font-medium text-red-700 dark:text-red-400">Esta ação não pode ser desfeita.</p>
                <p class="mt-0.5 text-xs text-red-600 dark:text-red-500">Todos os dados deste fornecedor serão removidos permanentemente.</p>
            </div>
        </div>

        <!-- Dados do fornecedor -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg divide-y divide-gray-100 dark:divide-gray-800 mb-6">

            <!-- Nome -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Nome)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @Html.DisplayFor(model => model.Nome)
                </p>
            </div>

            <!-- CNPJ -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.CNPJ)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @{
                        var cnpj = Model.CNPJ;
                        if (cnpj.Length == 14)
                        {
                            @(cnpj.Substring(0, 2) + "." + cnpj.Substring(2, 3) + "." + cnpj.Substring(5, 3) + "/" + cnpj.Substring(8, 4) + "-" + cnpj.Substring(12, 2))
                        }
                        else
                        {
                            @cnpj
                        }
                    }
                </p>
            </div>

            <!-- Email -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Email)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @Html.DisplayFor(model => model.Email)
                </p>
            </div>

            <!-- Telefone -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Telefone)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @{
                        var tel = Model.Telefone;
                        if (tel.Length == 11)
                        {
                            @("(" + tel.Substring(0, 2) + ") " + tel.Substring(2, 5) + "-" + tel.Substring(7, 4))
                        }
                        else if (tel.Length == 10)
                        {
                            @("(" + tel.Substring(0, 2) + ") " + tel.Substring(2, 4) + "-" + tel.Substring(6, 4))
                        }
                        else
                        {
                            @tel
                        }
                    }
                </p>
            </div>

        </div>

         <!-- Formulário de exclusão -->
         <form id="delete-form" asp-action="Delete" method="post" class="space-y-4">
             <input type="hidden" asp-for="Id" />
             <button type="button" id="open-modal-btn"
                     class="w-full py-2 px-4 border border-red-600 dark:border-red-500 text-sm font-medium text-red-600 dark:text-red-500 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 dark:hover:text-white rounded transition-colors duration-200">
                 Confirmar Exclusão
             </button>
         </form>

        <!-- Link Cancelar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index"
               class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Cancelar
            </a>
        </div>

     </div>
 </div>

 <!-- Modal de confirmação de exclusão -->
 <div id="deleteConfirmationModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
     <div class="fixed inset-0 bg-black/50 dark:bg-black/70 backdrop-blur-sm"></div>
     <div class="relative w-full max-w-sm mx-4 bg-white dark:bg-gray-950 rounded-lg shadow-lg border border-gray-200 dark:border-gray-800 p-6">
         <h3 class="text-lg font-medium text-black dark:text-white mb-3">Confirmar exclusão</h3>
         <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
             Tem certeza que deseja excluir o fornecedor <strong>@Model.Nome</strong>? Esta ação não pode ser desfeita.
         </p>
         <div class="flex gap-3">
             <button type="button" id="cancelDeleteBtn"
                     class="flex-1 py-2 px-4 border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-white bg-white dark:bg-gray-900 hover:bg-gray-50 dark:hover:bg-gray-800 rounded transition-colors duration-200">
                 Cancelar
             </button>
             <button type="button" id="confirmDeleteBtn"
                     class="flex-1 py-2 px-4 border border-red-600 dark:border-red-500 text-sm font-medium text-white bg-red-600 dark:bg-red-500 hover:bg-red-700 dark:hover:bg-red-600 rounded transition-colors duration-200">
                 Excluir
             </button>
         </div>
     </div>
 </div>

 @section Scripts {
     <script>
         const modal = document.getElementById('deleteConfirmationModal');
         document.getElementById('open-modal-btn').addEventListener('click', () => modal.classList.remove('hidden'));
         document.getElementById('cancelDeleteBtn').addEventListener('click', () => modal.classList.add('hidden'));
         document.getElementById('confirmDeleteBtn').addEventListener('click', () => { document.getElementById('delete-form').submit(); });
         modal.addEventListener('click', e => { if (e.target === modal) modal.classList.add('hidden'); });
     </script>
 }
