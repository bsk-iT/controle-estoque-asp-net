@model IEnumerable<SistemaControleDeEstoque.Models.Fornecedor>

@{
    ViewData["Title"] = "Fornecedores";
}

<!-- Cabeçalho -->
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
            style="font-family: 'Playfair Display', Georgia, serif;">
            Fornecedores
        </h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gerenciamento de fornecedores do sistema</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
            </div>
            <input type="text" id="pesquisa-fornecedores" placeholder="Pesquisar fornecedores..."
                   class="pl-9 pr-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150 w-56" />
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
        {
            <a asp-action="Create"
               class="inline-flex items-center gap-2 px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Novo
            </a>
        }
    </div>
</div>

<!-- Tabela -->
<div class="overflow-x-auto">
        <table id="tabela-fornecedores" class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
            <thead>
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.Nome)
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.CNPJ)
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.Email)
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        @Html.DisplayNameFor(model => model.Telefone)
                    </th>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                            Ações
                        </th>
                    }
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-950 transition-colors duration-100">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm font-medium text-gray-900 dark:text-white">@Html.DisplayFor(modelItem => item.Nome)</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm text-gray-500 dark:text-gray-400">
                                @{
                                    var cnpj = item.CNPJ;
                                    if (cnpj.Length == 14)
                                    {
                                        @(cnpj.Substring(0, 2) + "." + cnpj.Substring(2, 3) + "." + cnpj.Substring(5, 3) + "/" + cnpj.Substring(8, 4) + "-" + cnpj.Substring(12, 2))
                                    }
                                    else
                                    {
                                        @cnpj
                                    }
                                }
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm text-gray-500 dark:text-gray-400">@Html.DisplayFor(modelItem => item.Email)</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm text-gray-500 dark:text-gray-400">
                                @{
                                    var tel = item.Telefone;
                                    if (tel.Length == 11)
                                    {
                                        @("(" + tel.Substring(0, 2) + ") " + tel.Substring(2, 5) + "-" + tel.Substring(7, 4))
                                    }
                                    else if (tel.Length == 10)
                                    {
                                        @("(" + tel.Substring(0, 2) + ") " + tel.Substring(2, 4) + "-" + tel.Substring(6, 4))
                                    }
                                    else
                                    {
                                        @tel
                                    }
                                }
                            </span>
                        </td>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <td class="px-6 py-4 whitespace-nowrap text-right">
                                <div class="flex items-center justify-end gap-3">
                                    @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150"
                                           title="Editar">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
                                            </svg>
                                        </a>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150"
                                       title="Detalhes">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="text-gray-400 dark:text-gray-600 hover:text-red-600 dark:hover:text-red-500 transition-colors duration-150"
                                           title="Excluir">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                            </svg>
                                        </a>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

@section Scripts {
    <script>
        const table = new DataTable('#tabela-fornecedores', {
            language: {
                lengthMenu: '_MENU_ por página',
                info: '_START_–_END_ de _TOTAL_',
                infoEmpty: '0 registros',
                emptyTable: 'nenhum registro',
                zeroRecords: 'nenhum resultado',
            },
            pageLength: 10,
            columnDefs: [{ orderable: false, targets: -1 }],
            layout: { topEnd: null }
        });

        document.getElementById('pesquisa-fornecedores').addEventListener('input', function () {
            table.search(this.value).draw();
        });
    </script>
}
