@model IEnumerable<SistemaControleDeEstoque.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Cabeçalho -->
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
            style="font-family: 'Playfair Display', Georgia, serif;">Produtos</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gerenciamento de produtos do sistema</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
            </div>
            <input type="text" id="pesquisa-produtos" placeholder="Pesquisar produtos..."
                   class="pl-9 pr-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150 w-56" />
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
        {
            <a asp-action="Create"
               class="inline-flex items-center gap-2 px-4 py-2 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Novo
            </a>
        }
    </div>
</div>

<!-- Tabela -->
<div class="overflow-x-auto">
    <table id="tabela-produtos" class="min-w-full">
        <thead>
            <tr class="border-b border-gray-200 dark:border-gray-800">
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    @Html.DisplayNameFor(model => model.Nome)
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    @Html.DisplayNameFor(model => model.Tipo)
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    @Html.DisplayNameFor(model => model.Quantidade)
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    @Html.DisplayNameFor(model => model.Valor)
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    Valor Total
                </th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    @Html.DisplayNameFor(model => model.Fornecedor)
                </th>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Ações
                    </th>
                }
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800/60">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-900/40 transition-colors duration-100">
                    <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                        @Html.DisplayFor(modelItem => item.Nome)
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        @Html.DisplayFor(modelItem => item.Tipo)
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        @Html.DisplayFor(modelItem => item.Quantidade)
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        @item.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        @{
                            var valorTotal = item.Quantidade * item.Valor;
                            @valorTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                        }
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                        @if (item.Fornecedor != null)
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400">
                                @item.Fornecedor?.Nome
                            </span>
                        }
                        else
                        {
                            <span class="text-xs text-gray-400 dark:text-gray-600">—</span>
                        }
                    </td>
                     @if (User.Identity?.IsAuthenticated == true)
                     {
                         <td class="px-4 py-3 whitespace-nowrap text-right">
                             <div class="flex items-center justify-end gap-3">
                                 @if (item.EstoqueBaixo)
                                 {
                                     <span class="group relative cursor-help">
                                         <!-- Ícone de alerta (triângulo com exclamação) -->
                                         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500 dark:text-amber-400" viewBox="0 0 24 24" fill="currentColor">
                                             <path fill-rule="evenodd" d="M8.485 2.495c.674-1.166 2.334-1.166 3.008 0l7.894 13.683c.674 1.166-.169 2.606-1.504 2.606H3.095c-1.335 0-2.178-1.44-1.504-2.606L8.485 2.495zM10 5a1 1 0 011 1v5a1 1 0 11-2 0V6a1 1 0 011-1zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                                         </svg>
                                         
                                         <!-- Tooltip com números de quantidade -->
                                         <div class="absolute right-0 bottom-full mb-2 hidden group-hover:block whitespace-nowrap bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 text-xs font-medium py-1 px-3 rounded shadow-lg z-10">
                                             Estoque baixo: @item.Quantidade un. (mínimo: @item.EstoqueSeguranca un.)
                                         </div>
                                     </span>
                                 }
                                 @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                 {
                                     <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150"
                                       title="Editar">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150"
                                   title="Detalhes">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="text-gray-400 dark:text-gray-600 hover:text-red-600 dark:hover:text-red-500 transition-colors duration-150"
                                       title="Excluir">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </a>
                                }
                            </div>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const table = new DataTable('#tabela-produtos', {
            language: {
                lengthMenu: '_MENU_ por página',
                info: '_START_–_END_ de _TOTAL_',
                infoEmpty: '0 registros',
                emptyTable: 'nenhum registro',
                zeroRecords: 'nenhum resultado',
            },
            pageLength: 10,
            columnDefs: [{ orderable: false, targets: -1 }],
            layout: { topEnd: null }
        });

        document.getElementById('pesquisa-produtos').addEventListener('input', function () {
            table.search(this.value).draw();
        });
    </script>
}
