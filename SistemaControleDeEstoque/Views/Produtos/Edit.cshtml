@model SistemaControleDeEstoque.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var fornecedoresDisponiveis = ViewBag.FornecedoresDisponiveis as List<SistemaControleDeEstoque.Models.Fornecedor>;
    var produtoFornecedores = ViewBag.ProdutoFornecedores as List<SistemaControleDeEstoque.Models.ProdutoFornecedor>;
}

<div class="min-h-screen flex items-center justify-center py-12">
    <div class="w-full max-w-sm">

        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Editar Produto</h1>
        </div>

        <form asp-action="Edit" method="post" class="space-y-5">

            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-200 dark:border-red-800 rounded-md"
                 role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <!-- Grid de campos (coluna única) -->
            <div class="grid grid-cols-1 gap-5">

                <!-- Nome -->
                <div>
                    <label asp-for="Nome"
                           class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5"></label>
                    <input asp-for="Nome"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Nome" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Tipo -->
                <div>
                    <label asp-for="Tipo"
                           class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5"></label>
                    <input asp-for="Tipo"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Tipo" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Quantidade -->
                <div>
                    <label asp-for="Quantidade"
                           class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5"></label>
                    <input asp-for="Quantidade"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="Quantidade" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Valor -->
                <div>
                    <label asp-for="Valor"
                           class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5"></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-gray-400 dark:text-gray-500 text-sm">R$</span>
                        </div>
                        <input asp-for="Valor"
                               class="w-full pl-10 pr-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    </div>
                    <span asp-validation-for="Valor" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Fornecedor Principal -->
                <div>
                    <label asp-for="FornecedorId"
                           class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">
                        Fornecedor Principal
                    </label>
                    <select asp-for="FornecedorId" asp-items="ViewBag.FornecedorId"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                        <option value="">— Selecione um fornecedor principal —</option>
                    </select>
                    <span asp-validation-for="FornecedorId" class="mt-1 text-xs text-red-600 dark:text-red-400"></span>
                </div>

            </div>

            <!-- Fornecedores Adicionais -->
            <div class="space-y-4">
                <h2 class="text-sm font-medium text-gray-900 dark:text-white">Fornecedores Adicionais</h2>

                <!-- Fornecedores já associados -->
                <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 space-y-3">
                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Associados a este produto</p>

                    @if (produtoFornecedores != null && produtoFornecedores.Any())
                    {
                        <div class="space-y-2">
                            @foreach (var pf in produtoFornecedores)
                            {
                                <div class="flex items-center justify-between px-3 py-2 border border-gray-100 dark:border-gray-800 rounded-md">
                                    <div>
                                        <span class="text-sm font-medium text-gray-900 dark:text-white">@pf.Fornecedor.Nome</span>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">CNPJ: @pf.Fornecedor.CNPJ</p>
                                    </div>
                                    <a href="#"
                                       class="text-gray-400 dark:text-gray-600 hover:text-red-600 dark:hover:text-red-500 transition-colors duration-150"
                                       onclick="removeFornecedor(@pf.Id); return false;"
                                       title="Remover">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-gray-400 dark:text-gray-600">Nenhum fornecedor adicional associado.</p>
                    }
                </div>

                <!-- Adicionar novo fornecedor -->
                <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 space-y-3">
                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Adicionar fornecedor</p>
                    <div class="flex items-center gap-2">
                        <select id="novoFornecedor"
                                class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                            <option value="">— Selecione um fornecedor —</option>
                            @if (fornecedoresDisponiveis != null)
                            {
                                @foreach (var fornecedor in fornecedoresDisponiveis)
                                {
                                    <option value="@fornecedor.Id">@fornecedor.Nome</option>
                                }
                            }
                        </select>
                        <button type="button"
                                onclick="adicionarFornecedor()"
                                class="inline-flex items-center justify-center h-9 w-9 border border-black dark:border-white text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200"
                                title="Adicionar">
                            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Botão -->
            <div class="pt-2">
                <button type="submit"
                        class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                    Salvar
                </button>
            </div>

        </form>

        <!-- Rodapé com link Voltar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index"
               class="text-xs text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                Voltar
            </a>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function adicionarFornecedor() {
            const fornecedorId = document.getElementById('novoFornecedor').value;
            const produtoId = @Model.Id;

            if (!fornecedorId) {
                alert('Por favor, selecione um fornecedor para adicionar.');
                return;
            }

            fetch(`/api/ProdutosFornecedores`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    produtoId: produtoId,
                    fornecedorId: fornecedorId
                })
            })
            .then(response => {
                if (!response.ok) throw new Error('Erro ao adicionar fornecedor');
                return response.json();
            })
            .then(() => window.location.reload())
            .catch(error => {
                console.error('Erro:', error);
                alert('Ocorreu um erro ao adicionar o fornecedor. Tente novamente.');
            });
        }

        function removeFornecedor(produtoFornecedorId) {
            if (!confirm('Tem certeza que deseja remover este fornecedor?')) return;

            fetch(`/api/ProdutosFornecedores/${produtoFornecedorId}`, {
                method: 'DELETE',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (!response.ok) throw new Error('Erro ao remover fornecedor');
                window.location.reload();
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Ocorreu um erro ao remover o fornecedor. Tente novamente.');
            });
        }
    </script>
}

