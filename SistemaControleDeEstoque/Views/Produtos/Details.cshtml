@model SistemaControleDeEstoque.Models.Produto

@{
    ViewData["Title"] = "Detalhes do Produto";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var valorTotal = Model.Quantidade * Model.Valor;
}

<div class="flex justify-center pt-3">
    <div class="w-full max-w-sm">

        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Detalhes do Produto</h1>
        </div>

        <!-- Campos em lista vertical -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg divide-y divide-gray-100 dark:divide-gray-800 mb-6">

            <!-- Nome -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Nome)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@Html.DisplayFor(model => model.Nome)</p>
            </div>

            <!-- Tipo -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Tipo)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@Html.DisplayFor(model => model.Tipo)</p>
            </div>

            <!-- Quantidade -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Quantidade)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@Html.DisplayFor(model => model.Quantidade) unidade(s)</p>
            </div>

            <!-- Valor Unitário -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Valor)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @Model.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                </p>
            </div>

            <!-- Valor Total em Estoque -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    Valor Total em Estoque
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @valorTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                </p>
            </div>

            <!-- Fornecedor -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Fornecedor)
                </p>
                @if (Model?.Fornecedor != null)
                {
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400">
                        @Model.Fornecedor.Nome
                    </span>
                }
                else
                {
                    <span class="text-sm text-gray-400 dark:text-gray-600">Não cadastrado</span>
                }
            </div>

        </div>

        <!-- Ações -->
        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
        {
            <div class="pt-2">
                <a asp-action="Edit" asp-route-id="@Model?.Id"
                   class="w-full inline-flex items-center justify-center py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                    Editar
                </a>
            </div>
        }

        <!-- Rodapé com link Voltar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index"
               class="text-xs text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                Voltar
            </a>
        </div>

    </div>
</div>
