@model SistemaControleDeEstoque.Models.Relatorio

@{
    ViewData["Title"] = "Novo Relatório";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="flex justify-center pt-3">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Novo Relatório</h1>
        </div>

        <form asp-action="Create" method="post" class="space-y-6">

            <!-- Validação -->
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-200 dark:border-red-800 rounded-md" role="alert"></div>

            <!-- Grid de campos principais (coluna única) -->
            <div class="grid grid-cols-1 gap-5">
                <!-- Tipo -->
                <div>
                    <label asp-for="Tipo" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Tipo de Relatório</label>
                    <select asp-for="Tipo" id="Tipo"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                        <option value="">Selecione o tipo...</option>
                        <option value="@SistemaControleDeEstoque.Models.TipoRelatorio.Estoque">Inventário de Estoque</option>
                        <option value="@SistemaControleDeEstoque.Models.TipoRelatorio.Movimentacoes">Movimentações</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Data de Geração -->
                <div>
                    <label asp-for="DataGeracao" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Data de Geração</label>
                    <input asp-for="DataGeracao" type="datetime-local"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="DataGeracao" class="text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Responsável (somente leitura) -->
                <div>
                    <label asp-for="UsuarioGerador" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Responsável pela Geração</label>
                    <div class="flex items-center gap-2 px-3 py-2 border border-gray-200 dark:border-gray-800 rounded-md bg-gray-50 dark:bg-gray-900">
                        <svg class="h-4 w-4 text-gray-400 dark:text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <span class="text-sm text-gray-700 dark:text-gray-300">@Model.UsuarioGerador</span>
                    </div>
                    <input asp-for="UsuarioGerador" type="hidden" />
                    <p class="mt-1 text-xs text-gray-400 dark:text-gray-600">Preenchido automaticamente com o usuário logado.</p>
                </div>
            </div>

            <!-- Parâmetros do relatório -->
            <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 space-y-5">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Parâmetros do Relatório</p>

                <!-- Período -->
                <div class="grid grid-cols-1 gap-5">
                    <div>
                        <label asp-for="DataInicio" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Data Inicial</label>
                        <input asp-for="DataInicio" type="date"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                        <span asp-validation-for="DataInicio" class="text-xs text-red-600 dark:text-red-400"></span>
                        <p class="mt-1 text-xs text-gray-400 dark:text-gray-600">Se não informada, considera desde o início</p>
                    </div>
                    <div>
                        <label asp-for="DataFim" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Data Final</label>
                        <input asp-for="DataFim" type="date"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                        <span asp-validation-for="DataFim" class="text-xs text-red-600 dark:text-red-400"></span>
                        <p class="mt-1 text-xs text-gray-400 dark:text-gray-600">Se não informada, usa a data atual</p>
                    </div>
                </div>

                <!-- Parâmetros de estoque -->
                <div id="parametros-estoque" class="space-y-4 border-t border-gray-100 dark:border-gray-800 pt-4" style="display:none;">
                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Opções de Inventário</p>
                    <div class="space-y-3">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input asp-for="IncluirProdutosZerados" type="checkbox"
                                   class="h-4 w-4 rounded border-gray-300 dark:border-gray-700 text-black dark:text-white focus:ring-black dark:focus:ring-white" />
                            <span class="text-sm text-gray-700 dark:text-gray-300">Incluir produtos com estoque zerado</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input asp-for="ApenasAbaixoDoMinimo" type="checkbox"
                                   class="h-4 w-4 rounded border-gray-300 dark:border-gray-700 text-black dark:text-white focus:ring-black dark:focus:ring-white" />
                            <span class="text-sm text-gray-700 dark:text-gray-300">Apenas produtos abaixo do estoque mínimo</span>
                        </label>
                        <div>
                            <label asp-for="Ordenacao" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Ordenar por</label>
                            <select asp-for="Ordenacao"
                                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                                <option value="@SistemaControleDeEstoque.Models.OrdenacaoRelatorio.NomeProduto">Nome do Produto</option>
                                <option value="@SistemaControleDeEstoque.Models.OrdenacaoRelatorio.Quantidade">Quantidade</option>
                                <option value="@SistemaControleDeEstoque.Models.OrdenacaoRelatorio.Valor">Valor</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Parâmetros de movimentações -->
                <div id="parametros-movimentacoes" class="space-y-4 border-t border-gray-100 dark:border-gray-800 pt-4" style="display:none;">
                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Opções de Movimentações</p>
                    <div class="space-y-3">
                        <div>
                            <label asp-for="TipoMovimentacao" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Tipo de Movimentação</label>
                            <select asp-for="TipoMovimentacao"
                                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                                <option value="@SistemaControleDeEstoque.Models.FiltroTipoMovimentacao.Todas">Todas</option>
                                <option value="@SistemaControleDeEstoque.Models.FiltroTipoMovimentacao.Entradas">Entradas</option>
                                <option value="@SistemaControleDeEstoque.Models.FiltroTipoMovimentacao.Saidas">Saídas</option>
                            </select>
                        </div>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input asp-for="Resumido" type="checkbox"
                                   class="h-4 w-4 rounded border-gray-300 dark:border-gray-700 text-black dark:text-white focus:ring-black dark:focus:ring-white" />
                            <span class="text-sm text-gray-700 dark:text-gray-300">Visualização resumida (agrupada por produto)</span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Botão -->
            <button type="submit"
                    class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Gerar Relatório
            </button>
        </form>

        <!-- Link Voltar -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index"
               class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Voltar para Relatórios
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tipoSelect = document.getElementById('Tipo');
            const parametrosEstoque = document.getElementById('parametros-estoque');
            const parametrosMovimentacoes = document.getElementById('parametros-movimentacoes');

            function atualizarParametros() {
                const tipo = tipoSelect.value;

                if (tipo === '@((int)SistemaControleDeEstoque.Models.TipoRelatorio.Estoque)') {
                    parametrosEstoque.style.display = 'block';
                    parametrosMovimentacoes.style.display = 'none';
                }
                else if (tipo === '@((int)SistemaControleDeEstoque.Models.TipoRelatorio.Movimentacoes)') {
                    parametrosEstoque.style.display = 'none';
                    parametrosMovimentacoes.style.display = 'block';
                }
                else {
                    parametrosEstoque.style.display = 'none';
                    parametrosMovimentacoes.style.display = 'none';
                }
            }

            tipoSelect.addEventListener('change', atualizarParametros);
            atualizarParametros();
        });
    </script>
}
