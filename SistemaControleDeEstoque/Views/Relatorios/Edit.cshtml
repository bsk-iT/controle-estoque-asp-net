@model SistemaControleDeEstoque.Models.Relatorio

@{
    ViewData["Title"] = "Editar Relatório";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Wrapper centralizado -->
<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Editar Relatório</h1>
        </div>

        <form asp-action="Edit" method="post" class="space-y-5">
            <!-- Validação -->
            <div asp-validation-summary="ModelOnly"
                 class="text-sm text-red-600 dark:text-red-400 p-3 border border-red-200 dark:border-red-800 rounded-md" role="alert"></div>

            <input type="hidden" asp-for="Id" />

            <!-- Grid de campos: coluna única -->
            <div class="grid grid-cols-1 gap-5">
                <!-- Tipo -->
                <div>
                    <label asp-for="Tipo" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Tipo de Relatório</label>
                    <select asp-for="Tipo"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150">
                        <option value="">Selecione o tipo...</option>
                        <option value="Inventário de Estoque">Inventário de Estoque</option>
                        <option value="Movimentações">Movimentações</option>
                        <option value="Produtos mais vendidos">Produtos mais vendidos</option>
                        <option value="Relatório Financeiro">Relatório Financeiro</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Data de Geração -->
                <div>
                    <label asp-for="DataGeracao" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Data de Geração</label>
                    <input asp-for="DataGeracao" type="datetime-local"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="DataGeracao" class="text-xs text-red-600 dark:text-red-400"></span>
                </div>

                <!-- Usuário Gerador -->
                <div>
                    <label asp-for="UsuarioGerador" class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Responsável pela Geração</label>
                    <input asp-for="UsuarioGerador"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    <span asp-validation-for="UsuarioGerador" class="text-xs text-red-600 dark:text-red-400"></span>
                </div>
            </div>

            <!-- Parâmetros adicionais -->
            <div class="border border-gray-200 dark:border-gray-800 rounded-lg p-5 space-y-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Parâmetros Adicionais</p>
                <div class="grid grid-cols-1 gap-5">
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Data Inicial</label>
                        <input type="date" name="DataInicial"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Data Final</label>
                        <input type="date" name="DataFinal"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150" />
                    </div>
                </div>
            </div>

            <!-- Botão submit: w-full -->
            <button type="submit"
                    class="w-full py-2 px-4 border border-black dark:border-white text-sm font-medium text-black dark:text-white bg-transparent hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black rounded transition-colors duration-200">
                Salvar Alterações
            </button>
        </form>

        <!-- Rodapé: link de navegação -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index" class="text-xs text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                Voltar
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
