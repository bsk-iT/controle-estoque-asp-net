@model IEnumerable<Produto>

@{
    ViewData["Title"] = "Alertas de Estoque";
}

<!-- Cabeçalho -->
<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-light text-black dark:text-white tracking-tight"
            style="font-family: 'Playfair Display', Georgia, serif;">
            Alertas de Estoque
        </h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Produtos com estoque abaixo do nível de segurança. Reposição recomendada.</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
            </div>
            <input type="text" id="pesquisa-alertas" placeholder="Pesquisar alertas..."
                   class="pl-9 pr-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-white rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white transition-colors duration-150 w-56" />
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <!-- Estado vazio -->
    <div class="bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-lg p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-lg font-medium text-gray-900 dark:text-white mb-1">Nenhum alerta no momento</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Todos os produtos estão com estoque adequado.</p>
    </div>
}
else
{
    <!-- Tabela de alertas -->
    <div class="overflow-x-auto">
        <table id="tabela-alertas" class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
            <thead>
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Produto
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Tipo
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Qtd. Atual
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Qtd. Mínima
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Déficit
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Fornecedor
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                        Ações
                    </th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                @foreach (var produto in Model)
                {
                    var deficit = produto.EstoqueSeguranca - produto.Quantidade;
                    var severidade = deficit > produto.EstoqueSeguranca * 0.5 ? "high" : "medium";
                    var severidadeClass = severidade == "high"
                        ? "bg-red-50 dark:bg-red-950"
                        : "bg-amber-50 dark:bg-amber-950";
                    var badgeClass = severidade == "high"
                        ? "bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200"
                        : "bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-200";

                    <tr class="@severidadeClass hover:bg-gray-50 dark:hover:bg-gray-950 transition-colors duration-100">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm font-medium text-gray-900 dark:text-white">@produto.Nome</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm text-gray-500 dark:text-gray-400">@produto.Tipo</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <span class="text-sm font-medium text-gray-900 dark:text-white">@produto.Quantidade</span>
                            <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">un.</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <span class="text-sm font-medium text-gray-900 dark:text-white">@produto.EstoqueSeguranca</span>
                            <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">un.</span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                -@deficit un.
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="text-sm text-gray-500 dark:text-gray-400">
                                @if (produto.Fornecedor != null)
                                {
                                    @produto.Fornecedor?.Nome
                                }
                                else
                                {
                                    <span class="text-gray-400 dark:text-gray-500">Sem fornecedor</span>
                                }
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <div class="flex items-center justify-end gap-3">
                                <a asp-controller="Produtos" asp-action="Edit" asp-route-id="@produto.Id"
                                   title="Editar produto"
                                   class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
                                    </svg>
                                </a>
                                <a asp-controller="Produtos" asp-action="Details" asp-route-id="@produto.Id"
                                   title="Ver detalhes"
                                   class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors duration-150">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        const table = new DataTable('#tabela-alertas', {
            language: {
                lengthMenu: '_MENU_ por página',
                info: '_START_–_END_ de _TOTAL_',
                infoEmpty: '0 registros',
                emptyTable: 'nenhum registro',
                zeroRecords: 'nenhum resultado',
            },
            pageLength: 10,
            order: [[2, 'asc']],
            columnDefs: [{ orderable: false, targets: -1 }],
            layout: { topEnd: null }
        });

        document.getElementById('pesquisa-alertas').addEventListener('input', function () {
            table.search(this.value).draw();
        });
    </script>
}
