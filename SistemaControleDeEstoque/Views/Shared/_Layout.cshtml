@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SistemaControleDeEstoque.Data
@inject SignInManager<IdentityUser> SignInManager
@inject ApplicationDbContext Db

@{
    // Calculado uma vez aqui para evitar @{ } aninhado dentro de @if (erro de sintaxe Razor)
    var alertCount = 0;
    if (SignInManager.IsSignedIn(User) && (User.IsInRole("Gerente") || User.IsInRole("Admin")))
    {
        alertCount = await Db.Produto.CountAsync(p => p.Quantidade < p.EstoqueSeguranca);
    }
}

<!DOCTYPE html>
<html lang="pt-br" class="h-full">
<head>
    <!-- 1. Anti-FOUC: rodar ANTES de qualquer render para evitar flash de tema errado -->
    <script>
        // Versioning: se mudou de versão, reseta para light (limpa localStorage sujo de sessões antigas)
        if (localStorage.getItem('theme-v') !== '3') {
            localStorage.removeItem('theme');
            localStorage.setItem('theme-v', '3');
        }
        // Padrão é light — só ativa dark se o usuário escolheu explicitamente
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
        // Sem else: não força remoção aqui para não brigar com a classe do html
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - inventarii</title>

    <!-- Google Fonts: Playfair Display (logo/títulos) + Inter (corpo/nav) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- 2. Tailwind CDN PRIMEIRO — o CDN precisa carregar antes de receber o config -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 3. tailwind.config DEPOIS do CDN — o objeto tailwind já existe, aceita darkMode: 'class' -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        playfair: ['Playfair Display', 'Georgia', 'serif'],
                        inter: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        };
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.min.css" />
</head>
<body class="bg-gray-50 dark:bg-black flex flex-col min-h-full font-inter">

    <!-- HEADER -->
    <header class="bg-gray-50 dark:bg-black">
        <nav class="mx-auto px-6 lg:px-12 max-w-screen-xl">
            <div class="flex justify-between items-center h-16">

                <!-- LOGO -->
                <div class="flex-shrink-0">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-2 group">
                        <img src="~/images/logo-light.png"
                             alt="inventarii logo"
                             class="h-8 w-8 object-contain transition-all duration-300 dark:invert" />
                        <span class="font-playfair text-lg font-medium tracking-tight text-black dark:text-white"
                              style="font-family: 'Playfair Display', Georgia, serif; letter-spacing: -0.02em;">
                            inventarii
                        </span>
                    </a>
                </div>

                <!-- NAV LINKS (desktop) -->
                <div class="hidden md:flex items-center gap-8">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a asp-area="" asp-controller="Fornecedores" asp-action="Index"
                           class="text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors duration-150">
                            Fornecedores
                        </a>
                        <a asp-area="" asp-controller="Produtos" asp-action="Index"
                           class="text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors duration-150">
                            Produtos
                        </a>
                        <a asp-area="" asp-controller="Movimentacoes" asp-action="Index"
                           class="text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors duration-150">
                            Movimentações
                        </a>
                        <a asp-area="" asp-controller="Relatorios" asp-action="Index"
                           class="text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors duration-150">
                            Relatórios
                        </a>
                        
                        <!-- Link para Alertas (apenas Gerente e Admin) -->
                        @if (User.IsInRole("Gerente") || User.IsInRole("Admin"))
                        {
                            <a asp-area="" asp-controller="Alertas" asp-action="Index"
                               class="relative text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors duration-150 flex items-center gap-2">
                                Alertas
                                @if (alertCount > 0)
                                {
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-500 text-white text-xs font-bold">
                                        @alertCount
                                    </span>
                                }
                            </a>
                        }
                    }
                    <!-- Admin (apenas para role Admin) -->
                    <partial name="_LoginAdmin.cshtml" />
                </div>

                <!-- ÁREA DIREITA: toggle tema + botões auth -->
                <div class="hidden md:flex items-center gap-3">
                    <!-- Botão toggle dark/light: único ícone, inverte no dark -->
                    <button id="theme-toggle" type="button"
                            class="p-2 rounded-full border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-900 transition-colors duration-150"
                            aria-label="Alternar tema">
                        <img src="~/images/night-mode.png"
                             alt="Alternar tema"
                             class="h-5 w-5 object-contain dark:invert" />
                    </button>

                    <partial name="_LoginPartial" />
                </div>

                <!-- Hamburger (mobile) -->
                <div class="-mr-2 flex items-center md:hidden">
                    <button type="button" id="mobile-menu-button"
                            class="inline-flex items-center justify-center p-2 rounded-md text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-900 focus:outline-none transition-colors"
                            aria-expanded="false">
                        <span class="sr-only">Abrir menu</span>
                        <svg class="block h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>

            </div>

            <!-- MENU MOBILE -->
            <div class="md:hidden hidden border-t border-gray-100 dark:border-gray-800" id="mobile-menu">
                <div class="py-3 space-y-1">
                    <a asp-area="" asp-controller="Home" asp-action="Index"
                       class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                        Home
                    </a>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a asp-area="" asp-controller="Fornecedores" asp-action="Index"
                           class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                            Fornecedores
                        </a>
                        <a asp-area="" asp-controller="Produtos" asp-action="Index"
                           class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                            Produtos
                        </a>
                        <a asp-area="" asp-controller="Movimentacoes" asp-action="Index"
                           class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                            Movimentações
                        </a>
                        <a asp-area="" asp-controller="Relatorios" asp-action="Index"
                           class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                            Relatórios
                        </a>
                        
                        <!-- Link para Alertas (apenas Gerente e Admin) -->
                        @if (User.IsInRole("Gerente") || User.IsInRole("Admin"))
                        {
                            <a asp-area="" asp-controller="Alertas" asp-action="Index"
                               class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors flex items-center justify-between">
                                <span>Alertas</span>
                                @if (alertCount > 0)
                                {
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-500 text-white text-xs font-bold">
                                        @alertCount
                                    </span>
                                }
                            </a>
                        }
                    }
                    <partial name="_LoginAdminMobile" />
                    <!-- Auth mobile -->
                    <div class="pt-3 pb-2 px-4 border-t border-gray-100 dark:border-gray-800">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTEÚDO PRINCIPAL -->
    @{
        var mainClass = ViewData["FullHeight"] != null
            ? "w-full flex-grow flex flex-col overflow-hidden"
            : "w-full max-w-screen-xl mx-auto px-6 lg:px-12 py-8 flex-grow";
    }
    <div class="@mainClass">
        <!-- Aviso de Alerta (TempData) -->
        @if (TempData["AlertaEstoque"] != null)
        {
            <div id="alerta-estoque" class="mb-6 p-4 bg-amber-50 dark:bg-amber-950 border border-amber-200 dark:border-amber-800 rounded-lg flex items-start gap-3 animate-slide-down">
                <svg class="h-5 w-5 text-amber-600 dark:text-amber-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <div class="flex-grow">
                    <p class="text-sm text-amber-800 dark:text-amber-200">@TempData["AlertaEstoque"]</p>
                </div>
                <button type="button" onclick="document.getElementById('alerta-estoque').remove()" class="text-amber-600 dark:text-amber-400 hover:text-amber-800 dark:hover:text-amber-200 flex-shrink-0">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        }
        <main class="@(ViewData["FullHeight"] != null ? "flex-grow flex flex-col" : "")">@RenderBody()</main>
    </div>

    <!-- FOOTER -->
    <footer class="bg-gray-50 dark:bg-black border-t border-gray-200 dark:border-gray-800 mt-auto">
        <div class="max-w-screen-xl mx-auto py-6 px-6 lg:px-12">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <!-- Logo rodapé -->
                <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
                    <img src="~/images/logo-light.png"
                         alt="inventarii logo"
                         class="h-5 w-5 object-contain transition-all duration-300 dark:invert" />
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300" style="font-family: 'Playfair Display', serif;">inventarii</span>
                </a>
                <p class="text-xs text-gray-400 dark:text-gray-600">
                    &copy; @DateTime.Now.Year inventarii - Todos os direitos reservados.
                </p>
                <!-- Ícone de cadeado no lugar de "Privacidade" -->
                <a asp-area="" asp-controller="Home" asp-action="Privacy"
                   class="text-gray-400 dark:text-gray-600 hover:text-black dark:hover:text-white transition-colors"
                   title="Política de Privacidade">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M16.5 10.5V7.125C16.5 4.839 14.661 3 12.375 3h-.75C9.339 3 7.5 4.839 7.5 7.125V10.5M5.25 10.5h13.5A1.5 1.5 0 0 1 20.25 12v7.5A1.5 1.5 0 0 1 18.75 21H5.25A1.5 1.5 0 0 1 3.75 19.5V12A1.5 1.5 0 0 1 5.25 10.5Z" />
                    </svg>
                </a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Mobile menu toggle ──────────────────────────────────────
        var mobileBtn = document.getElementById('mobile-menu-button');
        if (mobileBtn) {
            mobileBtn.addEventListener('click', function () {
                document.getElementById('mobile-menu').classList.toggle('hidden');
            });
        }

        // ── Dark / Light mode toggle ────────────────────────────────
        var themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
            themeBtn.addEventListener('click', function () {
                var html = document.documentElement;
                var isDark = html.classList.toggle('dark');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
