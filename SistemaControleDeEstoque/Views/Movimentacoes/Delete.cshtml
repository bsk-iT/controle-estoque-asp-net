@model SistemaControleDeEstoque.Models.Movimentacao

@{
    ViewData["Title"] = "Excluir Movimentação";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="w-full max-w-sm">
        <!-- Cabeçalho centralizado -->
        <div class="mb-8 text-center">
            <p class="text-xs uppercase tracking-widest text-gray-400 dark:text-gray-600 mb-1">inventarii</p>
            <h1 class="text-2xl font-light text-red-600 dark:text-red-500 tracking-tight"
                style="font-family: 'Playfair Display', Georgia, serif;">Excluir Movimentação</h1>
        </div>

        <!-- Alerta de exclusão -->
        <div class="mb-6 border border-red-200 dark:border-red-900 rounded-lg p-4">
            <p class="text-sm font-medium text-red-700 dark:text-red-400">Tem certeza que deseja excluir esta movimentação?</p>
            <p class="text-sm text-red-600 dark:text-red-500 mt-1">Esta ação não pode ser desfeita e o registro será removido permanentemente.</p>
        </div>

        <!-- Campos em lista vertical -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-lg divide-y divide-gray-100 dark:divide-gray-800 mb-6">

            <!-- Tipo -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">
                    @Html.DisplayNameFor(model => model.Tipo)
                </p>
                @if (Model.Tipo?.ToLower() == "entrada")
                {
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-green-50 dark:bg-green-950 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800">
                        <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                        @Html.DisplayFor(model => model.Tipo)
                    </span>
                }
                else if (Model.Tipo?.ToLower() == "saída" || Model.Tipo?.ToLower() == "saida")
                {
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-red-50 dark:bg-red-950 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800">
                        <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                        @Html.DisplayFor(model => model.Tipo)
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400">
                        @Html.DisplayFor(model => model.Tipo)
                    </span>
                }
            </div>

            <!-- Quantidade -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.Quantidade)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">@Html.DisplayFor(model => model.Quantidade) unidade(s)</p>
            </div>

            <!-- Data Movimentação -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
                    @Html.DisplayNameFor(model => model.DataMovimentacao)
                </p>
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                    @Model.DataMovimentacao.ToString("dd/MM/yyyy HH:mm")
                </p>
            </div>

            <!-- Produto -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">
                    @Html.DisplayNameFor(model => model.Produto)
                </p>
                @if (Model.Produto?.Nome != null)
                {
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400">
                        @Model.Produto.Nome
                    </span>
                }
                else
                {
                    <span class="text-sm text-gray-400 dark:text-gray-600">Produto não disponível</span>
                }
            </div>

            <!-- Responsável -->
            <div class="px-6 py-4">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Responsável</p>
                <p class="flex items-center gap-2 text-sm font-medium text-gray-900 dark:text-white">
                    <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    @if (!string.IsNullOrEmpty(Model.UsuarioNome))
                    {
                        @Model.UsuarioNome
                    }
                    else
                    {
                        @Model.UsuarioId
                    }
                </p>
            </div>

        </div>

        <!-- Formulário de exclusão -->
        <form asp-action="Delete" onsubmit="return confirmarExclusao(event)">
            <input type="hidden" asp-for="Id" />
            <button type="submit"
                    class="w-full py-2 px-4 border border-red-600 dark:border-red-500 text-sm font-medium text-red-600 dark:text-red-500 bg-transparent hover:bg-red-600 hover:text-white dark:hover:bg-red-500 rounded transition-colors duration-200">
                Confirmar Exclusão
            </button>
        </form>

        <!-- Rodapé: link de navegação -->
        <div class="mt-6 border-t border-gray-100 dark:border-gray-900 pt-4 text-center">
            <a asp-action="Index" class="text-xs text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors duration-150">
                Cancelar
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarExclusao(event) {
            if (!window.confirm('Tem certeza que deseja excluir esta movimentação? Esta ação não pode ser desfeita.')) {
                event.preventDefault();
                return false;
            }
            return true;
        }
    </script>
}
