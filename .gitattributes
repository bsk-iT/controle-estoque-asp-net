###############################################################################
# Normalize line endings for all files
###############################################################################
* text=auto

###############################################################################
# C# and .NET files - use LF on all platforms
###############################################################################
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.xml text eol=lf

###############################################################################
# Web files - use LF on all platforms
###############################################################################
*.cshtml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.scss text eol=lf

###############################################################################
# Documentation
###############################################################################
*.md text eol=lf
*.txt text eol=lf

###############################################################################
# Git config
###############################################################################
.gitignore text eol=lf
.gitattributes text eol=lf

###############################################################################
# Binary files
###############################################################################
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary